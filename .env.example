# MongoDB Docker Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=secret

# MongoDB Connection String (used by backend)
MONGO_URI=mongodb://admin:secret@localhost:27017/studio_db?authSource=admin

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# Server
PORT=5001
NODE_ENV=development

# Seed admin credentials
SEED_ADMIN_USERNAME=superadmin
SEED_ADMIN_PASSWORD=Admin@1234
